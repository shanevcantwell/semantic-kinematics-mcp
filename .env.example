# Semantic Kinematics Configuration
# Copy this file to .env and adjust for your hardware.

# ============================================================================
# Embedding Backend
# ============================================================================
# Options: nv_embed, lmstudio, sentence_transformers
#
# nv_embed:              NV-Embed-v2 via PyTorch (~28GB VRAM fp32, ~14GB fp16)
# lmstudio:              Any GGUF model via LM Studio OpenAI-compatible API
# sentence_transformers: Any HuggingFace model via sentence-transformers
EMBEDDING_BACKEND=nv_embed

# Model name for API-based backends (lmstudio, sentence_transformers)
# Only used when EMBEDDING_BACKEND is not nv_embed.
# EMBEDDING_MODEL=text-embedding-embeddinggemma-300m

# API URL for lmstudio backend
# EMBEDDING_SERVER_URL=http://localhost:1234/v1
